{
  "version": 2,
  "builds": [
    {
      "src": "packages/frontend/next.config.js",
      "use": "@vercel/next",
      "config": {
        "project": "packages/frontend",
        "distDir": ".next"
      }
    },
    {
      "src": "packages/backend/server.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "/packages/backend/server.py"
    },
    {
      "source": "/(.*)",
      "destination": "/packages/frontend/$1"
    }
  ]
} 