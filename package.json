{
  "name": "copypaste-checker",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd packages/backend && python -m uvicorn server:app --reload --port 8000",
    "dev:frontend": "cd packages/frontend && npm run dev",
    "backend": "cd packages/backend && python -m uvicorn server:app --reload --port 8000",
    "frontend": "cd packages/frontend && npm run dev",
    "build": "npm run build:frontend",
    "build:frontend": "cd packages/frontend ; npm run build",
    "install:all": "npm install && cd packages/backend && npm install && cd ../frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
} 